{
  "name": "nuxt-directus-sdk",
  "type": "module",
  "version": "5.0.1-beta.1",
  "description": "A Directus nuxt module that uses the Directus SDK",
  "author": "Matthew Rollinson <matt@rolley.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rolleyio/nuxt-directus-sdk"
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./rules": {
      "types": "./dist/rules/index.d.mts",
      "import": "./dist/rules/index.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "bin": {
    "directus-rules": "dist/cli/index.mjs",
    "nuxt-directus-sdk": "dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "bun run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt prepare playground",
    "release": "npm run lint && npm run prepack && npm publish && git push --follow-tags",
    "release:next": "npm run lint && npm run prepack && npm publish --tag next && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "docs:dev": "bun run dev:prepare && vitepress dev docs",
    "docs:build": "bun run dev:prepare && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "@directus/sdk": ">=20.0.0",
    "@directus/types": ">=13.0.0",
    "@directus/visual-editing": ">=1.1.0",
    "@nuxt/image": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@directus/types": {
      "optional": true
    },
    "@directus/visual-editing": {
      "optional": true
    },
    "@nuxt/image": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "defu": "^6.1.7",
    "directus-sdk-typegen": "^0.2.1",
    "http-proxy": "^1.18.1",
    "ufo": "^1.6.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@directus/sdk": "^20.0.0",
    "@directus/types": "^13.0.0",
    "@directus/visual-editing": "^1.1.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/image": "^2.0.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/http-proxy": "^1.17.17",
    "changelogen": "^0.6.1",
    "eslint": "^10.2.0",
    "nuxt": "^4.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.0.8"
  },
  "unbuild": {
    "failOnWarn": false,
    "externals": [
      "consola/utils"
    ]
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "sharp"
  ]
}
