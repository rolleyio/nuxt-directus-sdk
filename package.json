{
  "name": "nuxt-directus-sdk",
  "version": "5.0.0-beta.8",
  "description": "A Directus nuxt module that uses the Directus SDK",
  "license": "MIT",
  "author": "Matthew Rollinson <matt@rolley.io>",
  "bin": {
    "directus-rules": "./dist/cli/index.mjs",
    "nuxt-directus-sdk": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./rules": {
      "types": "./dist/rules/index.d.mts",
      "import": "./dist/rules/index.mjs"
    }
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build --stub && nuxi prepare playground",
    "release": "npm run lint && npm run prepack && npm publish && git push --follow-tags",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "docs:dev": "bun run dev:prepare && vitepress dev docs",
    "docs:build": "bun run dev:prepare && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt --ignore-path .oxfmtignore",
    "format:check": "oxfmt --check --ignore-path .oxfmtignore",
    "typecheck": "tsc --noEmit",
    "postinstall": "lefthook install",
    "changelog": "changelogen"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "change-case": "^4.1.2",
    "defu": "^6.1.1",
    "directus-sdk-typegen": "^0.2.1",
    "http-proxy": "^1.18.1",
    "ufo": "^1.6.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.10.0",
    "@directus/sdk": "^20.0.0",
    "@directus/types": "^13.0.0",
    "@directus/visual-editing": "^1.1.0",
    "@evilmartians/lefthook": "^2.1.1",
    "@nuxt/devtools": "latest",
    "@nuxt/image": "^2.0.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.1.2",
    "@nuxt/test-utils": "^3.19.2",
    "@types/http-proxy": "^1.17.17",
    "changelogen": "^0.6.2",
    "eslint": "^9.22.0",
    "nuxt": "^4.1.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.0.8",
    "vue-tsc": "^3.0.8"
  },
  "peerDependencies": {
    "@directus/sdk": ">=20.0.0",
    "@directus/types": ">=13.0.0",
    "@directus/visual-editing": ">=1.1.0",
    "@nuxt/image": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@directus/types": {
      "optional": true
    },
    "@directus/visual-editing": {
      "optional": true
    },
    "@nuxt/image": {
      "optional": true
    }
  },
  "unbuild": {
    "failOnWarn": false,
    "externals": [
      "consola/utils"
    ]
  }
}
